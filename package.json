{
  "name": "myhairloss-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/generate-static-content.js && next build",
    "start": "next start",
    "pages:build": "node scripts/generate-static-content.js && npx @cloudflare/next-on-pages",
    "pages:deploy": "npx wrangler pages deploy .vercel/output/static --project-name=myhairloss-site",
    "pages:publish": "npm run pages:build && npm run pages:deploy"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.20",
    "framer-motion": "^12.40.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.18.0",
    "next": "^14.2.35",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "reading-time": "^1.5.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "resend": "^6.14.0",
    "rss": "^1.2.2",
    "stripe": "^22.3.2",
    "unified": "^11.0.4"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.8.4",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "wrangler": "^4.0.0"
  }
}
